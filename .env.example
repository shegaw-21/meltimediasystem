# Azure Blob Storage Configuration
# Uncomment and fill these to use cloud storage for videos, audio, and transcripts

# Storage Account Name (e.g., meltimediastoragexxxxx)
# AZURE_STORAGE_ACCOUNT_NAME=

# Storage Account Key (required for upload and server sync)
# AZURE_STORAGE_ACCOUNT_KEY=

# Alternatively provide a full Azure storage connection string:
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Use cloud storage instead of local files
# Set to 'true' to enable cloud storage, 'false' or unset to use local files
USE_CLOUD_STORAGE=false

# Cloud storage URLs (format: https://<account>.blob.core.windows.net/<container>/)
# These are automatically populated after deployment, but can be manually set
# CLOUD_VIDEOS_URL=
# CLOUD_AUDIO_URL=
# CLOUD_TRANSCRIPTS_URL=

# Backend Port
PORT=3000

# Environment
NODE_ENV=development
